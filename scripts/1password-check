#!/usr/bin/env sh
set -eu

root="$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)"
config="$root/.foundry/secrets/1password.yaml"

fail() {
  echo "$*" >&2
  exit 1
}

test -f "$config" || fail "missing 1Password config: .foundry/secrets/1password.yaml"

admin_vault="$(sed -n 's/^  adminVault: "\([^"]*\)"$/\1/p' "$config")"
shared_vault="$(sed -n 's/^  sharedVault: "\([^"]*\)"$/\1/p' "$config")"
service_account_ref="$(sed -n 's/^  serviceAccountRef: "\(op:\/\/[^"]*\)"$/\1/p' "$config")"

test -n "$admin_vault" || fail "1Password adminVault must be configured"
test -n "$shared_vault" || fail "1Password sharedVault must be configured"
printf '%s' "$service_account_ref" | grep -Eq '^op://[^/]+/[^/]+/[^/]+$' || fail "1Password serviceAccountRef must be an op:// reference"

for forbidden in OP_SERVICE_ACCOUNT_TOKEN access_key secret_key password: token:; do
  if grep -Fq "$forbidden" "$config"; then
    fail "1Password config must not contain plaintext secret material: $forbidden"
  fi
done

if [ "${FOUNDRY_OP_LIVE_CHECK:-0}" = "1" ]; then
  command -v op >/dev/null 2>&1 || fail "op CLI is required when FOUNDRY_OP_LIVE_CHECK=1"
  op read "$service_account_ref" >/dev/null
else
  echo "live 1Password check skipped; set FOUNDRY_OP_LIVE_CHECK=1 to verify op access"
fi
