#!/usr/bin/env sh
set -eu

root="$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)"
account_config="$root/infra/aws/account.yaml"
provider="$root/infra/terraform/aws-provider.tf"
secret_tf="$root/infra/terraform/aws-secrets-manager-secret.tf"

fail() {
  echo "$*" >&2
  exit 1
}

test -f "$account_config" || fail "missing AWS account config: infra/aws/account.yaml"
test -f "$provider" || fail "missing AWS provider file: infra/terraform/aws-provider.tf"
test -f "$secret_tf" || fail "missing Secrets Manager resource file: infra/terraform/aws-secrets-manager-secret.tf"

"$root/scripts/terraform-state-check" >/dev/null

account_id="$(sed -n 's/^  accountId: "\([0-9][0-9]*\)"$/\1/p' "$account_config")"
region="$(sed -n 's/^  region: "\([^"]*\)"$/\1/p' "$account_config")"
profile="$(sed -n 's/^  profile: "\([^"]*\)"$/\1/p' "$account_config")"
name="$(sed -n 's/^  name                    = "\([^"]*\)"$/\1/p' "$secret_tf")"
recovery_window="$(sed -n 's/^  recovery_window_in_days = \([0-9][0-9]*\)$/\1/p' "$secret_tf")"

printf '%s' "$name" | grep -Eq '^/[A-Za-z0-9/_+=.@-]+$' || fail "Secrets Manager secret name must be an absolute path"
test -n "$recovery_window" || fail "Secrets Manager recovery window must be configured"
if [ "$recovery_window" = "0" ]; then
  case "$name" in
    /foundry/smoke/*) ;;
    *) fail "recovery_window_in_days 0 is allowed only for /foundry/smoke/ secrets" ;;
  esac
elif [ "$recovery_window" -lt 7 ] || [ "$recovery_window" -gt 30 ]; then
  fail "Secrets Manager recovery window must be 0 or 7-30 days"
fi

grep -Fq 'source  = "hashicorp/aws"' "$provider" || fail "AWS provider source must be hashicorp/aws"
grep -Fq 'version = "= 6.52.0"' "$provider" || fail "AWS provider version must be exactly pinned"
grep -Fq "region              = \"$region\"" "$provider" || fail "AWS provider region must match aws:account"
grep -Fq "allowed_account_ids = [\"$account_id\"]" "$provider" || fail "AWS provider must pin allowed_account_ids"
grep -Fq 'resource "aws_secretsmanager_secret" "foundry_managed"' "$secret_tf" || fail "Secrets Manager secret container resource must exist"
grep -Fq 'ManagedBy = "project-foundry"' "$secret_tf" || fail "Secrets Manager secret must be tagged"

for forbidden in 'resource "aws_secretsmanager_secret_version"' secret_string secret_binary random_password plaintext 'password =' 'token =' access_key secret_key; do
  if grep -Fq "$forbidden" "$secret_tf"; then
    fail "aws:secrets-manager-secret must not manage secret values"
  fi
done

if [ "${FOUNDRY_AWS_SECRETS_MANAGER_SECRET_LIVE_CHECK:-0}" = "1" ]; then
  command -v aws >/dev/null 2>&1 || fail "aws CLI is required when FOUNDRY_AWS_SECRETS_MANAGER_SECRET_LIVE_CHECK=1"
  actual_name="$(aws secretsmanager describe-secret --secret-id "$name" --profile "$profile" --region "$region" --query Name --output text)"
  test "$actual_name" = "$name" || fail "live Secrets Manager secret name must match generated config"
else
  echo "live Secrets Manager check skipped; set FOUNDRY_AWS_SECRETS_MANAGER_SECRET_LIVE_CHECK=1 after terraform apply"
fi
