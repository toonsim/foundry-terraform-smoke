#!/usr/bin/env sh
set -eu

root="$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)"
identity="$root/infra/aws/terraform-identity.yaml"
trust_policy="$root/infra/aws/terraform-identity-trust-policy.json"
workflow="$root/.github/workflows/terraform-identity-check.yml.example"

fail() {
  echo "$*" >&2
  exit 1
}

test -f "$identity" || fail "missing Terraform identity file: infra/aws/terraform-identity.yaml"
test -f "$trust_policy" || fail "missing Terraform identity trust policy"
test -f "$workflow" || fail "missing Terraform identity workflow example"

role_arn="$(sed -n 's/^  roleArn: "\(arn:aws:iam::[0-9][0-9]*:role\/[^"]*\)"$/\1/p' "$identity")"
github_subject="$(sed -n 's/^  githubSubject: "\(repo:[^"]*\)"$/\1/p' "$identity")"
bootstrap_ref="$(sed -n 's/^    bootstrapRef: "\(op:\/\/[^"]*\)"$/\1/p' "$identity")"

printf '%s' "$role_arn" | grep -Eq '^arn:aws:iam::[0-9]{12}:role/[A-Za-z0-9+=,.@_/-]+$' || fail "Terraform identity roleArn must be an IAM role ARN"
printf '%s' "$github_subject" | grep -Eq '^repo:[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+:(ref:refs/(heads|tags)/[A-Za-z0-9_./-]+|environment:[A-Za-z0-9_.-]+)$' || fail "GitHub OIDC subject must be exact"
printf '%s' "$bootstrap_ref" | grep -Eq '^op://[^/]+/[^/]+/[^/]+$' || fail "Terraform identity bootstrapRef must be an op:// reference"

grep -Fq '"Action": "sts:AssumeRoleWithWebIdentity"' "$trust_policy" || fail "trust policy must use AssumeRoleWithWebIdentity"
grep -Fq '"token.actions.githubusercontent.com:aud": "sts.amazonaws.com"' "$trust_policy" || fail "trust policy must pin OIDC audience"
grep -Fq "\"token.actions.githubusercontent.com:sub\": \"$github_subject\"" "$trust_policy" || fail "trust policy must pin the GitHub subject"
grep -Fq 'id-token: write' "$workflow" || fail "workflow example must request id-token write"
grep -Fq 'aws-actions/configure-aws-credentials@e7f100cf4c008499ea8adda475de1042d6975c7b' "$workflow" || fail "workflow example must pin configure-aws-credentials by commit"

for forbidden in access_key secret_key AWS_ACCESS_KEY_ID AWS_SECRET_ACCESS_KEY; do
  if grep -R -Fq "$forbidden" "$identity" "$trust_policy" "$workflow"; then
    fail "Terraform identity must not contain long-lived AWS credential material: $forbidden"
  fi
done
