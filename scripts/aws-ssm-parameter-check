#!/usr/bin/env sh
set -eu

root="$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)"
account_config="$root/infra/aws/account.yaml"
provider="$root/infra/terraform/aws-provider.tf"
parameter_tf="$root/infra/terraform/aws-ssm-parameter.tf"

fail() {
  echo "$*" >&2
  exit 1
}

non_secret_config() {
  lower="$(printf '%s' "$1" | tr '[:upper:]' '[:lower:]')"
  for forbidden in secret password passwd token api_key apikey access_key secret_key private_key credential; do
    if printf '%s' "$lower" | grep -Fq "$forbidden"; then
      fail "SSM parameter must contain only non-secret config"
    fi
  done
  case "$lower" in
    sk-*|ghp_*|akia*|asia*) fail "SSM parameter must contain only non-secret config" ;;
  esac
}

test -f "$account_config" || fail "missing AWS account config: infra/aws/account.yaml"
test -f "$provider" || fail "missing AWS provider file: infra/terraform/aws-provider.tf"
test -f "$parameter_tf" || fail "missing SSM parameter resource file: infra/terraform/aws-ssm-parameter.tf"

"$root/scripts/terraform-state-check" >/dev/null

account_id="$(sed -n 's/^  accountId: "\([0-9][0-9]*\)"$/\1/p' "$account_config")"
region="$(sed -n 's/^  region: "\([^"]*\)"$/\1/p' "$account_config")"
profile="$(sed -n 's/^  profile: "\([^"]*\)"$/\1/p' "$account_config")"
name="$(sed -n 's/^  name  = "\([^"]*\)"$/\1/p' "$parameter_tf")"
value="$(sed -n 's/^  value = "\([^"]*\)"$/\1/p' "$parameter_tf")"

printf '%s' "$name" | grep -Eq '^/[A-Za-z0-9_./-]+$' || fail "SSM parameter name must be an absolute path"
test -n "$value" || fail "SSM parameter value must be configured"
non_secret_config "$name"
non_secret_config "$value"

grep -Fq 'source  = "hashicorp/aws"' "$provider" || fail "AWS provider source must be hashicorp/aws"
grep -Fq 'version = "= 6.52.0"' "$provider" || fail "AWS provider version must be exactly pinned"
grep -Fq "region              = \"$region\"" "$provider" || fail "AWS provider region must match aws:account"
grep -Fq "allowed_account_ids = [\"$account_id\"]" "$provider" || fail "AWS provider must pin allowed_account_ids"
grep -Fq 'resource "aws_ssm_parameter" "foundry_managed"' "$parameter_tf" || fail "SSM parameter resource must exist"
grep -Fq 'type  = "String"' "$parameter_tf" || fail "SSM parameter type must be String"
grep -Fq 'ManagedBy = "project-foundry"' "$parameter_tf" || fail "SSM parameter must be tagged"

if grep -Fq 'SecureString' "$parameter_tf"; then
  fail "aws:ssm-parameter must not use SecureString; use a secrets capability instead"
fi

for forbidden in access_key secret_key token; do
  if grep -R -Fq "$forbidden" "$provider" "$parameter_tf"; then
    fail "SSM parameter capability must not commit $forbidden"
  fi
done

if [ "${FOUNDRY_AWS_SSM_PARAMETER_LIVE_CHECK:-0}" = "1" ]; then
  command -v aws >/dev/null 2>&1 || fail "aws CLI is required when FOUNDRY_AWS_SSM_PARAMETER_LIVE_CHECK=1"
  actual_type="$(aws ssm get-parameter --name "$name" --profile "$profile" --region "$region" --query 'Parameter.Type' --output text)"
  test "$actual_type" = "String" || fail "live SSM parameter type must be String"
  actual_value="$(aws ssm get-parameter --name "$name" --profile "$profile" --region "$region" --query 'Parameter.Value' --output text)"
  test "$actual_value" = "$value" || fail "live SSM parameter value must match generated config"
else
  echo "live SSM parameter check skipped; set FOUNDRY_AWS_SSM_PARAMETER_LIVE_CHECK=1 after terraform apply"
fi
