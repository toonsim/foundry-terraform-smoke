{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ListTerraformStatePrefix",
      "Effect": "Allow",
      "Action": "s3:ListBucket",
      "Resource": "arn:aws:s3:::foundry-tfstate-273613910635-eu-west-1-foundry-terraform-smoke",
      "Condition": {
        "StringEquals": {
          "s3:prefix": "foundry-terraform-smoke/terraform.tfstate"
        }
      }
    },
    {
      "Sid": "ReadWriteTerraformState",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:PutObject"
      ],
      "Resource": "arn:aws:s3:::foundry-tfstate-273613910635-eu-west-1-foundry-terraform-smoke/foundry-terraform-smoke/terraform.tfstate"
    },
    {
      "Sid": "ManageTerraformStateLock",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:PutObject",
        "s3:DeleteObject"
      ],
      "Resource": "arn:aws:s3:::foundry-tfstate-273613910635-eu-west-1-foundry-terraform-smoke/foundry-terraform-smoke/terraform.tfstate.tflock"
    }
  ]
}
